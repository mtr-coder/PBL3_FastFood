<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<!-- Thử kết nối local với Windows Authentication -->
		<add name="QL_FASTFOOD"
			 connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=QL_FASTFOOD;Integrated Security=True;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />

		<!-- Hoặc dùng SQL Authentication (uncomment nếu cần) -->
		<!--<add name="QL_FASTFOOD"
			 connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=QL_FASTFOOD;User ID=fastfood_user;Password=fastfood;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />-->

		<!-- Hoặc kết nối remote (uncomment và điền IP đúng) -->
		<!--<add name="QL_FASTFOOD"
			 connectionString="Data Source=10.2.0.2\SQLEXPRESS;Initial Catalog=QL_FASTFOOD;User ID=fastfood_user;Password=fastfood;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />-->
	</connectionStrings>
</configuration>
